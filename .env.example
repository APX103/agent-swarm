# Agent Swarm 环境变量配置
# 复制此文件为 .env 并填入真实值

# LLM 配置（默认使用 GLM Coding Plan）
LLM_DEFAULT_MODEL=glm-coding-plan
LLM_DEFAULT_BASE_URL=https://open.bigmodel.cn/api/coding/paas/v4
LLM_DEFAULT_API_KEY=your_api_key_here

# 服务器配置
SERVER_HOST=0.0.0.0
SERVER_PORT=9000

# Redis（Agent 注册中心，必须先起好再启动 Swarm）
REDIS_URL=redis://localhost:6379

# 容器池配置（内置 Docker worker 池；纯外部 Agent 场景设 0 可跳过）
CONTAINER_POOL_SIZE=5
CONTAINER_BASE_PORT=9001
CONTAINER_IMAGE_NAME=agent-swarm-worker:latest
CONTAINER_MEM_LIMIT=512m
CONTAINER_CPU_LIMIT=1.0

# 存储配置
SHARED_OUTPUT_BASE=/home/apx103/work/swarm/shared_output

# 日志级别
LOG_LEVEL=INFO
