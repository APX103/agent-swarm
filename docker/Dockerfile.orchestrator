FROM python:3.12-slim

WORKDIR /app

# 安装系统依赖（Docker SDK 需要 docker CLI）
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    && rm -rf /var/lib/apt/lists/*

# 安装 Python 依赖
COPY requirements-orchestrator.txt .
RUN pip install --no-cache-dir -r requirements-orchestrator.txt

# 复制源代码
COPY src/ /app/src/
COPY config/ /app/config/
COPY pyproject.toml .

# 创建共享输出目录
RUN mkdir -p /workspace/shared_output

EXPOSE 9000

CMD ["python", "-m", "uvicorn", "src.main:app", "--host", "0.0.0.0", "--port", "9000"]
