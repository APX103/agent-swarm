# Agent Swarm - 项目配置
# 默认配置文件

server:
  host: "0.0.0.0"
  port: 8000

# 默认 LLM 配置
llm:
  default_model: "glm-4.7"
  default_base_url: "https://open.bigmodel.cn/api/coding/paas/v4"
  default_api_key: YOUR_API_KEY_HERE

# 容器池配置
container_pool:
  pool_size: 5            # 预启动容器数
  max_overflow: 3         # 溢出上限
  max_container_uses: 50  # 容器最大使用次数
  image_name: "swarm-worker:latest"
  network_name: "swarm-net"
  base_port: 9001         # Worker 端口起始
  mem_limit: "512m"
  cpu_limit: 0.5

# 存储配置
storage:
  shared_output_base: "/home/apx103/work/swarm/shared_output"

# 超时配置（秒）
timeouts:
  agent_startup: 30
  task_execution: 600
  container_checkout: 10

# Agent Card 预定义
agent_cards:
  - id: "frontend-engineer"
    name: "Frontend Engineer"
    description: "专业前端工程师，擅长 React/Vue/TypeScript、响应式 UI、组件化与无障碍设计"
    skills:
      - id: "frontend-engineer"
        name: "Frontend Development"
        description: "开发响应式前端应用"
        tags: ["frontend", "react", "vue", "typescript", "ui", "css", "html"]

  - id: "backend-engineer"
    name: "Backend Engineer"
    description: "专业后端工程师，擅长 API 设计、数据库建模、Python/FastAPI/Node.js 服务端"
    skills:
      - id: "backend-engineer"
        name: "Backend Development"
        description: "开发 RESTful API、数据库设计、服务端逻辑"
        tags: ["backend", "api", "database", "python", "node", "fastapi"]

  - id: "fullstack-engineer"
    name: "Fullstack Engineer"
    description: "全栈工程师，能独立打通前后端、从数据库到 UI 端到端交付"
    skills:
      - id: "fullstack-engineer"
        name: "Fullstack Development"
        description: "端到端全栈开发"
        tags: ["fullstack", "frontend", "backend"]

  - id: "devops-engineer"
    name: "DevOps Engineer"
    description: "DevOps 工程师，擅长 Docker/K8s、CI/CD 流水线、部署与监控"
    skills:
      - id: "devops-engineer"
        name: "DevOps"
        description: "容器化、CI/CD、部署、监控"
        tags: ["devops", "docker", "kubernetes", "ci-cd"]

  - id: "qa-engineer"
    name: "QA Engineer"
    description: "测试工程师，擅长单元/集成/E2E 测试、缺陷分析与质量保障"
    skills:
      - id: "qa-engineer"
        name: "Quality Assurance"
        description: "测试编写、缺陷分析、质量保障"
        tags: ["qa", "testing", "unit-test", "e2e"]

  - id: "security-engineer"
    name: "Security Engineer"
    description: "安全工程师，擅长漏洞评估、输入校验、鉴权与安全编码审查"
    skills:
      - id: "security-engineer"
        name: "Security"
        description: "漏洞评估、鉴权、安全编码审查"
        tags: ["security", "auth", "vulnerability"]

  - id: "data-engineer"
    name: "Data Engineer"
    description: "数据工程师，擅长数据管道、ETL、SQL 与数据分析脚本"
    skills:
      - id: "data-engineer"
        name: "Data Engineering"
        description: "数据管道、ETL、数据分析"
        tags: ["data", "etl", "sql", "analytics"]

  - id: "mobile-engineer"
    name: "Mobile Engineer"
    description: "移动端工程师，擅长 React Native/Flutter、iOS/Android 适配"
    skills:
      - id: "mobile-engineer"
        name: "Mobile Development"
        description: "移动端应用开发"
        tags: ["mobile", "react-native", "flutter", "ios", "android"]

  - id: "tech-writer"
    name: "Technical Writer"
    description: "技术文档工程师，擅长 README/API 文档、架构说明与用户指南"
    skills:
      - id: "tech-writer"
        name: "Technical Writing"
        description: "技术文档、API 文档、用户指南"
        tags: ["docs", "writing", "readme"]

  - id: "design-reviewer"
    name: "Design Reviewer"
    description: "设计评审专家，擅长 UI/UX 审查、可用性与视觉一致性评估"
    skills:
      - id: "design-reviewer"
        name: "Design Review"
        description: "UI/UX 审查、可用性评估"
        tags: ["design", "review", "ux", "usability"]

  - id: "general-agent"
    name: "General Agent"
    description: "通用 Agent，可以处理各种编程和非编程任务"
    skills:
      - id: "general"
        name: "General Task"
        description: "处理通用任务"
        tags: ["general", "coding", "writing", "analysis"]

# 编排器配置（可插拔调度 Agent）
orchestrator:
  provider: "builtin"            # "builtin" | "external"
  external_endpoint: ""          # 外部调度 Agent 的 A2A URL（provider=external 时必填）
  external_timeout: 600
  fallback: true                 # 外部不可用时自动回退内置（日志 + 事件显式标注，不静默吞错）

# 调度器配置
dispatcher:
  max_retries: 2                 # 失败重试次数（切候选 Agent）
  dispatch_timeout: 300          # 单次 dispatch 超时（秒）
  max_concurrent: 8              # 全局并发上限（背压）
  health_precheck: true          # dispatch 前健康预检

# API Key 保护（可选，内网防误调用。设了之后 /api/v1/ 路由需要 X-API-Key header）
# api_key: "your-secret-key"     # 或环境变量 SWARM_API_KEY

# Worker 开发模式（可选，volume 挂载 src/agents 到容器，改 worker 代码不用 rebuild 镜像）
# worker_dev_mode: false         # 或环境变量 WORKER_DEV_MODE=true
